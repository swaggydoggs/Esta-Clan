require('dotenv').config();
const fs = require('fs');
const path = require('path');
const { Client, GatewayIntentBits, Collection } = require('discord.js');

// Message Content Intent is required to read message text for prefix commands.
// Enable it in the Discord Developer Portal: Bot tab -> Privileged Gateway Intents.
const client = new Client({
  intents: [
    GatewayIntentBits.Guilds,
    GatewayIntentBits.GuildMessages,
    GatewayIntentBits.MessageContent,
  ],
});

// ---- Load commands from ./commands ----
// Every file in commands/ must export { name, execute(message, args) }
client.commands = new Collection();
const commandsPath = path.join(__dirname, 'commands');
const commandFiles = fs.readdirSync(commandsPath).filter((file) => file.endsWith('.js'));

for (const file of commandFiles) {
  const command = require(path.join(commandsPath, file));
  if (command?.name && typeof command.execute === 'function') {
    client.commands.set(command.name, command);
    console.log(`Loaded command: ${command.name}`);
  } else {
    console.warn(`Skipped ${file}: missing "name" or "execute"`);
  }
}

// ---- Load events from ./events ----
// Every file in events/ must export { name, once, execute(...args) }
const eventsPath = path.join(__dirname, 'events');
const eventFiles = fs.readdirSync(eventsPath).filter((file) => file.endsWith('.js'));

for (const file of eventFiles) {
  const event = require(path.join(eventsPath, file));
  if (event?.name && typeof event.execute === 'function') {
    if (event.once) {
      client.once(event.name, (...args) => event.execute(...args));
    } else {
      client.on(event.name, (...args) => event.execute(...args));
    }
    console.log(`Loaded event: ${event.name}`);
  } else {
    console.warn(`Skipped ${file}: missing "name" or "execute"`);
  }
}

client.login(process.env.DISCORD_TOKEN);
